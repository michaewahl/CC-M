# CC-M — Claude Model Router
CCM_PORT=8082
CCM_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model tier mapping (defaults shown)
# CCM_MODEL_SIMPLE=claude-haiku-4-5-20251001
# CCM_MODEL_MEDIUM=claude-sonnet-4-6
# CCM_MODEL_COMPLEX=claude-opus-4-6

# Classification thresholds (defaults shown)
# CCM_THRESHOLD_MEDIUM=1.5
# CCM_THRESHOLD_COMPLEX=3.5

# Force a specific model (bypasses classifier)
# CCM_FORCE_MODEL=claude-sonnet-4-6

# Cost tracking
# CCM_STORE_PATH=~/.cc-m/cost.db

# Logging
# CCM_LOG_CLASSIFICATIONS=true

# Shadow calibration (opt-in)
# CCM_CALIBRATION_ENABLED=false
# CCM_CALIBRATION_SAMPLE_RATE=0.2
# CCM_CALIBRATION_MAX_PROMPTS=50
